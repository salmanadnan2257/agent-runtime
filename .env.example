# API key for the AnthropicAdapter (only needed for live runs, never for tests)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# API key for the OpenAIAdapter (only needed for live runs, never for tests)
OPENAI_API_KEY=sk-your-key-here
# Path to the SQLite event store (default: ./agentrun.db)
AGENTRUN_DB=agentrun.db
# Comma-separated hostnames the http_get tool may reach (empty blocks all)
AGENTRUN_HTTP_ALLOWLIST=example.com,api.example.org
